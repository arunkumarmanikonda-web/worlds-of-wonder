{
  "name": "wow-booking-api",
  "version": "1.0.0",
  "description": "Worlds of Wonder — Booking Platform Backend API",
  "main": "src/server.js",
  "scripts": {
    "start":      "node src/server.js",
    "dev":        "nodemon src/server.js",
    "migrate":    "node src/scripts/migrate.js",
    "seed":       "node src/scripts/seed.js",
    "setup-db":   "node src/scripts/setup-db.js",
    "test-conn":  "node src/scripts/test-connection.js",
    "test":       "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "joi":                "^17.11.0",
    "jsonwebtoken":       "^9.0.2",
    "morgan":             "^1.10.0",
    "pg":                 "^8.11.3",
    "qrcode":             "^1.5.3",
    "razorpay":           "^2.9.2",
    "redis":              "^4.6.10",
    "uuid":               "^9.0.0"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "nodemon":   "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "engines": { "node": ">=18.0.0" },
  "author": "WOW Tech Team",
  "license": "UNLICENSED"
}