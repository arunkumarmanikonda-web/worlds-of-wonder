# ============================================================
#  WOW Booking API — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://wow_user:wow_pass@localhost:5432/wow_bookings

# Individual fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wow_bookings
DB_USER=wow_user
DB_PASS=wow_pass
DB_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# If Redis has a password:
# REDIS_URL=redis://:yourpassword@localhost:6379

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_256_BIT_SECRET_KEY_HERE
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── Razorpay ─────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use test keys for development (rzp_test_...)
# Use live keys for production  (rzp_live_...)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YYYYYYYYYYYYYYYYYYYYYYYY
RAZORPAY_WEBHOOK_SECRET=ZZZZZZZZZZZZZZZZZZZZZZZZ

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://yourdomain.com

# ── Rate Limiting ────────────────────────────────────────────
# Requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
BOOKING_RATE_LIMIT_MAX=20

# ── GST ──────────────────────────────────────────────────────
# GSTIN of the business (for invoice generation)
COMPANY_GSTIN=07AAAAA0000A1Z5
COMPANY_NAME=Entertainment and Amusement Ltd
COMPANY_ADDRESS=Sector 38A, Noida, Uttar Pradesh 201303

# ── QR Code ──────────────────────────────────────────────────
# Base URL embedded in QR codes (your frontend domain)
QR_BASE_URL=https://wow.yourwebsite.com/verify

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
